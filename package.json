{
  "name": "kenuxa",
  "version": "1.0.0",
  "private": true,
  "description": "Africa's Unified Intelligence Infrastructure — KENUXA Ecosystem Monorepo",
  "scripts": {
    "dev":          "turbo run dev",
    "build":        "turbo run build",
    "typecheck":    "turbo run typecheck",
    "lint":         "turbo run lint",
    "clean":        "turbo run clean",
    "dev:core":     "turbo run dev --filter=@kenuxa/core",
    "dev:reach":    "turbo run dev --filter=@kenuxa/reach",
    "dev:network":  "turbo run dev --filter=@kenuxa/network",
    "build:pkgs":   "turbo run build --filter=./packages/*"
  },
  "workspaces": [
    "apps/core",
    "apps/ops",
    "apps/reach",
    "apps/network",
    "packages/*"
  ],
  "devDependencies": {
    "turbo":      "^2.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
