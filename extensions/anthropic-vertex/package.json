{
  "name": "@KENUXA OPS/anthropic-vertex-provider",
  "version": "2026.5.26",
  "description": "KENUXA OPS Anthropic Vertex provider plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/KENUXA OPS/KENUXA OPS"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "0.16.1",
    "@earendil-works/pi-agent-core": "0.75.5",
    "@earendil-works/pi-ai": "0.75.5"
  },
  "devDependencies": {
    "@KENUXA OPS/plugin-sdk": "workspace:*"
  },
  "KENUXA OPS": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@KENUXA OPS/anthropic-vertex-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.5.26"
    },
    "build": {
      "KENUXA OPSVersion": "2026.5.26",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
