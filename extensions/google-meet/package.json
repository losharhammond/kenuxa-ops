{
  "name": "@KENUXA OPS/google-meet",
  "version": "2026.5.26",
  "description": "KENUXA OPS Google Meet participant plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/KENUXA OPS/KENUXA OPS"
  },
  "type": "module",
  "dependencies": {
    "commander": "14.0.3",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@KENUXA OPS/plugin-sdk": "workspace:*",
    "KENUXA OPS": "workspace:*"
  },
  "peerDependencies": {
    "KENUXA OPS": ">=2026.5.26"
  },
  "peerDependenciesMeta": {
    "KENUXA OPS": {
      "optional": true
    }
  },
  "KENUXA OPS": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@KENUXA OPS/google-meet",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.5.26"
    },
    "build": {
      "KENUXA OPSVersion": "2026.5.26"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
