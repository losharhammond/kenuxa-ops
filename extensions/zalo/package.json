{
  "name": "@KENUXA OPS/zalo",
  "version": "2026.5.26",
  "description": "KENUXA OPS Zalo channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/KENUXA OPS/KENUXA OPS"
  },
  "type": "module",
  "devDependencies": {
    "@KENUXA OPS/plugin-sdk": "workspace:*",
    "KENUXA OPS": "workspace:*"
  },
  "peerDependencies": {
    "KENUXA OPS": ">=2026.5.26"
  },
  "peerDependenciesMeta": {
    "KENUXA OPS": {
      "optional": true
    }
  },
  "KENUXA OPS": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "zalo",
      "label": "Zalo",
      "selectionLabel": "Zalo (Bot API)",
      "docsPath": "/channels/zalo",
      "docsLabel": "zalo",
      "blurb": "Vietnam-focused messaging platform with Bot API.",
      "aliases": [
        "zl"
      ],
      "order": 80,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@KENUXA OPS/zalo",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.26"
    },
    "build": {
      "KENUXA OPSVersion": "2026.5.26"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
