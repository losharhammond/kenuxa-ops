# =============================================================================
# KENUXA ECOSYSTEM — ROOT ENVIRONMENT VARIABLES
# Copy to each app as .env.local and fill in the values
# =============================================================================

# --- KENUXA CORE (ecosystem OS) ---
KENUXA_CORE_URL=http://localhost:3000
KENUXA_CORE_API_KEY=                        # internal service-to-service key

# --- SUPABASE (each app has its own Supabase project) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- JWT FEDERATION ---
JWT_SECRET=                                  # 64-char minimum — same across ecosystem for token validation

# --- AI PROVIDERS — separate keys per app for isolated rate limits ---
# Core keys (AI Gateway)
GROQ_CORE_API_KEY=
GROQ_REACH_API_KEY=
GROQ_OPS_API_KEY=
GROQ_ZURIA_API_KEY=
GROQ_ACADEMY_API_KEY=

# Additional providers (Core AI Gateway will route to these)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Voice
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Embeddings (fallback if using external service)
COHERE_API_KEY=

# --- PAYMENTS ---
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# --- COMMUNICATIONS ---
RESEND_API_KEY=
SMTP_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# --- INFRASTRUCTURE ---
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=                                 # Upstash Redis token (if using Upstash)

# --- APP URLS ---
APP_URL=http://localhost:3000
REACH_URL=http://localhost:3001
OPS_URL=http://localhost:3002
ZURIA_URL=http://localhost:3003

# --- SECURITY ---
WEBHOOK_SECRET=
ADMIN_SECRET=                                # Used to bootstrap first admin account
