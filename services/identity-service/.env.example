# KENUXA ACADEMY — Identity Service
# Copy to .env and fill in values.

# ── PostgreSQL (Academy-specific tables) ────────────────────
# Can point to the same Supabase project as Network (Transaction Pooler mode)
# or a separate Postgres DB for Academy data only.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/kenuxa_academy"

# ── Supabase (shared with KENUXA NETWORK) ───────────────────
# Use the SAME Supabase project as Network so accounts are shared.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"    # from Supabase project settings > API > JWT Secret

# ── KENUXA CORE (wallet + events + graph) ───────────────────
KENUXA_CORE_URL="http://localhost:3000"
KENUXA_CORE_API_KEY="your-core-api-key"

# ── Service settings ─────────────────────────────────────────
PORT=4001
CORS_ORIGIN="http://localhost:3003"
NODE_ENV=development
