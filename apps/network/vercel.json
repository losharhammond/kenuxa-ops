{
  "crons": [
    {
      "path": "/api/treasury/refresh-rates",
      "schedule": "0 * * * *",
      "headers": { "Authorization": "Bearer $CRON_SECRET" }
    },
    {
      "path": "/api/cron/credit-batch",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/settlement-sweep",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/market-prices-update",
      "schedule": "0 6,12,18 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    }
      ]
    }
  ]
}
