# ─── Supabase ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Admin Access (Email-based) ────────────────────────────────────
# Only users with these emails can see admin features and access /admin
# Comma-separated list (spaces after commas are trimmed)
ADMIN_EMAILS=admin@kenuxa.com,losharhammond@gmail.com,blueskyinfotechgh@gmail.com

# ─── KENUX Economy ─────────────────────────────────────────────────
KENUX_WELCOME_BONUS=500
NEXT_PUBLIC_KENUX_TO_GHS_RATE=0.1

# ─── External Services ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_key
NEXT_PUBLIC_GROQ_MODEL=mixtral-8x7b-32768

# ─── Vercel Cron (Free tier: 1 execution per day) ──────────────────
# Format: 0 X * * * (daily at hour X)
CRON_SCHEDULE=0 2 * * *
