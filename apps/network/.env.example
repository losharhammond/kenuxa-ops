# ============================================================
# KENUXA BUSINESS NETWORK — Complete Environment Configuration
# Copy to .env.local and fill in all values before running.
# Never commit .env.local to version control.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Application ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_APP_NAME=KENUXA Business Network
NEXT_PUBLIC_APP_ENV=development
# Options: development | staging | production
NODE_ENV=development

# ── KENUXA Core (mono-repo integration) ─────────────────────
KENUXA_CORE_URL=http://localhost:3000
KENUXA_CORE_API_KEY=your-core-api-key
KENUXA_CORE_WEBHOOK_SECRET=your-core-webhook-secret

# ── KENUX Economy ───────────────────────────────────────────
# Fixed rate: 10 KENUX = GH₵ 1.00 (KENUX is NOT cryptocurrency, NOT speculative)
KENUX_PER_GHS=10
# Legacy alias (deprecated, use KENUX_PER_GHS)
KENUX_GHS_RATE=10
# Welcome bonus in KENUX points
KENUX_WELCOME_BONUS=500
# Daily earn cap per user
KENUX_DAILY_EARN_CAP=1000

# ── AI Services ─────────────────────────────────────────────
# Primary: Groq (fast inference)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Secondary: OpenAI (fallback / embeddings)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Payments — Paystack (Primary: GH, NG, ZA, KE) ──────────
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# Paystack test keys (development)
# PAYSTACK_SECRET_KEY=sk_test_your-test-key
# PAYSTACK_PUBLIC_KEY=pk_test_your-test-key
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-test-key

# ── Payments — Flutterwave (Secondary: KE, UG, TZ, RW, CI) ─
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your-flutterwave-key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your-flutterwave-public-key
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your-flutterwave-public-key
FLUTTERWAVE_WEBHOOK_SECRET=your-flutterwave-webhook-secret

# ── Payments — MTN MoMo (Direct API) ────────────────────────
MTN_MOMO_API_KEY=your-mtn-momo-api-key
MTN_MOMO_USER_ID=your-mtn-momo-user-id
MTN_MOMO_SUBSCRIPTION_KEY=your-mtn-subscription-key
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
# Options: sandbox | production
MTN_MOMO_ENV=sandbox

# ── Payments — Telecel Cash (AirtelTigo) ────────────────────
TELECEL_API_KEY=your-telecel-api-key
TELECEL_MERCHANT_ID=your-telecel-merchant-id
TELECEL_BASE_URL=https://api.telecel.com.gh

# ── KENUX Treasury ──────────────────────────────────────────
KENUX_TREASURY_RESERVE_WALLET=your-treasury-wallet-id
KENUX_MAX_SUPPLY=100000000
KENUX_MINT_AUTHORITY_KEY=your-mint-authority-key

# ── Exchange Rates ──────────────────────────────────────────
# OpenExchangeRates (primary)
EXCHANGE_RATES_API_KEY=your-openexchangerates-app-id
# Cache duration in seconds (default: 3600 = 1 hour)
EXCHANGE_RATES_CACHE_TTL=3600

# ── Storage ─────────────────────────────────────────────────
# Supabase Storage (default — buckets created via migration)
NEXT_PUBLIC_STORAGE_URL=https://your-project.supabase.co/storage/v1

# Cloudflare R2 (optional CDN alternative)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=kenuxa-assets
R2_PUBLIC_URL=https://cdn.kenuxa.com

# ── Maps & Location ─────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key
# Ghana-first bounding box for autocomplete
NEXT_PUBLIC_MAPS_DEFAULT_LAT=5.6037
NEXT_PUBLIC_MAPS_DEFAULT_LNG=-0.1870
NEXT_PUBLIC_MAPS_DEFAULT_COUNTRY=gh

# ── Email — Resend ──────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@kenuxa.com
RESEND_FROM_NAME=KENUXA Network

# ── SMS — Arkesel (Ghana-first) ─────────────────────────────
ARKESEL_API_KEY=your-arkesel-api-key
ARKESEL_SENDER_ID=KENUXA
# Fallback: Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Push Notifications — Firebase ───────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour-key\n-----END PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your-app-id

# ── Cache — Upstash Redis ────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Search — Typesense ──────────────────────────────────────
TYPESENSE_HOST=your-typesense-host
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=your-typesense-api-key
NEXT_PUBLIC_TYPESENSE_SEARCH_KEY=your-typesense-search-only-key

# ── Analytics — PostHog ─────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Error Monitoring — Sentry ────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=kenuxa-network

# ── Logging — Betterstack / Logtail ─────────────────────────
BETTERSTACK_TOKEN=your-betterstack-source-token

# ── Security ────────────────────────────────────────────────
# 32-byte hex string for AES encryption at rest
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-add-a-very-complicated-32-byte-hex-string-here-for-encryption-at-rest
# HMAC secret for webhook signature verification
WEBHOOK_HMAC_SECRET=your-webhook-hmac-secret-add-a-very-complicated-32-byte-hex-string-here-for-signature-verification
# JWT secret for internal service auth
INTERNAL_JWT_SECRET=your-internal-jwt-secret-add-a-very-complicated-32-byte-hex-string-here-for-jwt-signing
# Admin dashboard auth (separate from user auth)
ADMIN_SECRET_KEY=your-admin-secret-key-add-a-very-complicated-32-byte-hex-string-here-for-admin-dashboard-auth

# ── Rate Limiting ────────────────────────────────────────────
# Max API requests per IP per minute
RATE_LIMIT_REQUESTS_PER_MINUTE=60
# Auth endpoints (stricter)
RATE_LIMIT_AUTH_PER_MINUTE=10
# Payment endpoints
RATE_LIMIT_PAYMENT_PER_MINUTE=30

# ── KYC / Identity Verification — Smile Identity ────────────
SMILE_PARTNER_ID=your-smile-partner-id
SMILE_API_KEY=your-smile-api-key
SMILE_CALLBACK_URL=https://network.kenuxa.com/api/kyc/smile/callback
SMILE_BASE_URL=https://3eydmgh10d.execute-api.us-west-2.amazonaws.com/v1

# ── Tax / Compliance — GRA EFRIS (Ghana) ────────────────────
GRA_EFRIS_URL=https://efrisws.erca.go.ke/api
GRA_EFRIS_USERNAME=your-gra-username
GRA_EFRIS_PASSWORD=your-gra-password
GRA_EFRIS_DEVICE_NUMBER=your-device-number

# ── Business Intelligence ────────────────────────────────────
# ClickHouse (analytics database)
CLICKHOUSE_HOST=your-clickhouse-host
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=kenuxa_analytics
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=your-clickhouse-password

# Metabase (BI dashboards)
METABASE_SITE_URL=https://your-metabase.example.com
METABASE_SECRET_KEY=your-metabase-secret-key

# ── Feature Flags ────────────────────────────────────────────
# Options: true | false
NEXT_PUBLIC_FEATURE_KENUX_WALLET=true
NEXT_PUBLIC_FEATURE_AI_COPILOT=true
NEXT_PUBLIC_FEATURE_FINANCIAL_SERVICES=true
NEXT_PUBLIC_FEATURE_MULTI_CURRENCY=true
NEXT_PUBLIC_FEATURE_MARKETPLACE_ESCROW=true
NEXT_PUBLIC_FEATURE_DELIVERY_TRACKING=true
NEXT_PUBLIC_FEATURE_BNPL=false
NEXT_PUBLIC_FEATURE_INSURANCE=false

# ── Docker / Deployment ──────────────────────────────────────
# Set to "1" during Docker builds for standalone Next.js output
DOCKER_BUILD=0
# Health check endpoint
HEALTH_CHECK_SECRET=your-health-check-secret

# ── E2E Testing (Playwright) ─────────────────────────────────
TEST_USER_EMAIL=test@kenuxa.com
TEST_USER_PASSWORD=TestPassword123!
TEST_BUSINESS_ID=test-business-id
