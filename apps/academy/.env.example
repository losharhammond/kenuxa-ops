# KENUXA ACADEMY — Web App
# Use the SAME Supabase project as KENUXA NETWORK for shared accounts.

# ── Supabase (SAME project as Network) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ── Identity Service (Academy-specific data) ─────────────────
NEXT_PUBLIC_IDENTITY_URL="http://localhost:4001"

# ── KENUXA CORE (wallet display) ─────────────────────────────
NEXT_PUBLIC_CORE_URL="http://localhost:3000"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3003"
NODE_ENV=development
