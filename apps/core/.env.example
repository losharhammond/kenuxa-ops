# KENUXA CORE — Environment Variables
# Copy to .env.local and fill in all values
# Generate secure keys: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ─── Supabase (Core's own Supabase project) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ─── JWT — MUST MATCH in ALL other KENUXA apps ───────────────
JWT_SECRET=replace-with-64-char-hex

# ─── AI — Separate Groq key per app ─────────────────────────
GROQ_API_KEY=gsk_              # legacy — maps to GROQ_CORE_API_KEY
GROQ_CORE_API_KEY=gsk_
GROQ_REACH_API_KEY=gsk_
GROQ_OPS_API_KEY=gsk_
GROQ_ZURIA_API_KEY=gsk_
GROQ_ACADEMY_API_KEY=gsk_

# ─── Additional AI Providers ─────────────────────────────────
OPENAI_API_KEY=sk-
ANTHROPIC_API_KEY=sk-ant-
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ─── Payments ────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_

# ─── Email ───────────────────────────────────────────────────
RESEND_API_KEY=re_
SMTP_URL=

# ─── Infrastructure ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=

# ─── Ecosystem Service Auth ──────────────────────────────────
KENUXA_CORE_API_KEY=          # shared with all KENUXA apps
ADMIN_SECRET=

APP_URL=http://localhost:3000
