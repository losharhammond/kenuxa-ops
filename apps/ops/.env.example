# ── KENUXA OPS — Environment Variables ────────────────────────────────────────

# Supabase (shared with ecosystem)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq (dedicated OPS key for independent rate limits)
GROQ_OPS_API_KEY=gsk_your_ops_groq_key

# KENUXA CORE integration
KENUXA_CORE_URL=http://localhost:3000
KENUXA_CORE_API_KEY=your-service-key
NEXT_PUBLIC_KENUXA_CORE_URL=http://localhost:3000

# JWT (shared ecosystem secret)
JWT_SECRET=your-shared-ecosystem-jwt-secret

# Email (Resend for sending, IMAP for reading)
RESEND_API_KEY=re_your_resend_key
GMAIL_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_CLIENT_SECRET=your-gmail-oauth-secret
GMAIL_REDIRECT_URI=http://localhost:3002/api/email/oauth/callback

# WebSocket
NEXT_PUBLIC_WS_URL=ws://localhost:3002

# Voice (optional Whisper API for enhanced STT)
OPENAI_API_KEY=sk-optional-for-whisper-fallback

# ── Phase 3: Upstash Redis Queue ────────────────────────────────────────────────
# Get from: https://console.upstash.com → Create Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Phase 3: External Playwright Worker ─────────────────────────────────────────
# Deploy playwright-worker to Railway/Render/Fly.io — leave blank to use Groq simulation
PLAYWRIGHT_WORKER_URL=https://your-worker.railway.app
PLAYWRIGHT_WORKER_SECRET=your-worker-secret

# ── Phase 3: Queue Processor Secret (for Vercel Cron) ───────────────────────────
# Vercel Cron passes this as X-Queue-Secret header to authenticate /api/queue/process
QUEUE_PROCESSOR_SECRET=your-queue-processor-secret

# ── Phase 5.2: Electron Desktop Bridge ─────────────────────────────────────────
# Local Electron bridge agent — listens at this URL
DESKTOP_BRIDGE_URL=http://localhost:7411
DESKTOP_BRIDGE_SECRET=your-bridge-secret

# ── Phase 4: Microsoft Graph API (Outlook primary email) ───────────────────────
# Register app at: https://portal.azure.com → App registrations → New registration
# Redirect URI: {APP_URL}/api/auth/microsoft/callback
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://your-ops-app.vercel.app/api/auth/microsoft/callback

# App
NEXT_PUBLIC_APP_NAME=KENUXA OPS
NEXT_PUBLIC_APP_URL=http://localhost:3002
NODE_ENV=development
